# Playwright Configurations
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000
IGNORE_HTTPS_ERRORS=false

# Application URL
TEST_BASE_URL=https://www.bus-data.dft.gov.uk
TEST_DATA_URL=https://data.bus-data.dft.gov.uk
TEST_PUBLISH_URL=https://publish.bus-data.dft.gov.uk

# User Credentials for testing
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpass123

# Expected page elements
EXPECTED_HOME_TITLE=Bus Open Data Service
TEST_ORGANISATION_NAME=Kainos

# CSS Selectors (customize for your app)
SELECTOR_LOGIN_BUTTON=text=Sign in
SELECTOR_LOGO=img[alt="BODS Logo"]





